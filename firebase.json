{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "*.firebaserc",
      ".git/**",
      ".github/**",
      "**/node_modules/**",
      "functions/**",
      "*.py",
      "*.md",
      "requirements.txt",
      "cricnow-scraper.py",
      "cricnow-server.py"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          },
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  },
  "database": {
    "rules": "database.rules.json"
  }
}
